DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Secret used to sign admin dashboard session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Optional: set these in your local .env (never committed) and run
# `npm run db:seed` to create/update your admin login.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
# Optional: display name shown in the dashboard greeting.
ADMIN_SEED_NAME=

# Cloudinary — used to upload and host product photos from the dashboard.
# Get these from your Cloudinary account dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
